% full commands
\def\@mechvar{\if@stressfree\stress\fi\if@strainfree\strain\fi}
\def\@elvar{\if@efieldfree\efield\fi\if@dfieldfree\dfield\fi}
\def\@thermvar{\if@temperaturefree\temperature\fi\if@entropydensityfree\entropydensity\fi}
\newcommand{\polarization}{\polarizationsymbol}
\newcommand{\efield}{\efieldsymbol}
\newcommand{\dfield}{\dfieldsymbol}
\newcommand{\stress}{\stresssymbol}
\newcommand{\strain}{\strainsymbol}
\newcommand{\temperature}{\temperaturesymbol}
\newcommand{\entropydensity}{\entropydensitysymbol}
\newcommand{\stiffness}{%
  \def\first{\@elvar}%
  \def\second{\@thermvar}%
  \def\alt{\@ifempty{\second}\relax\else,\second\fi}
\stiffnesssymbol^{\first\@ifempty{\first}\second\else\alt\fi}}
\newcommand{\compliance}{%
  \def\first{\@elvar}%
  \def\second{\@thermvar}%
  \def\alt{\@ifempty{\second}\relax\else,\second\fi}
\compliancesymbol^{\first\@ifempty{\first}\second\else\alt\fi}}
\newcommand{\permittivity}{%
  \def\first{\@mechvar}%
  \def\second{\@thermvar}%
  \def\alt{\@ifempty{\second}\relax\else,\second\fi}
\permittivitysymbol^{\first\@ifempty{\first}\second\else\alt\fi}}
\newcommand{\impermittivity}{%
  \def\first{\@mechvar}%
  \def\second{\@thermvar}%
  \def\alt{\@ifempty{\second}\relax\else,\second\fi}
\impermittivitysymbol^{\first\@ifempty{\first}\second\else\alt\fi}}
\newcommand{\piezoh}{%
    \def\first{\@thermvar}%
\piezohsymbol^{\first}}
\newcommand{\piezog}{%
    \def\first{\@thermvar}%
\piezogsymbol^{\first}}
\newcommand{\piezoe}{%
    \def\first{\@thermvar}%
\piezoesymbol^{\first}}
\newcommand{\piezod}{%
    \def\first{\@thermvar}%
\piezodsymbol^{\first}}
\newcommand{\heatcapacity}{%
  \def\first{\@mechvar}%
